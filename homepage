<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bluero — Kumpir Co.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --blue: #1A35CC;
      --blue-dark: #0d1f8a;
      --white: #FAFCFF;
      --cream: #F0F4FF;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-snap-type: y mandatory; overflow-y: scroll; scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--white); color: #111; cursor: none; }

    .cursor {
      width: 12px; height: 12px; background: var(--blue); border-radius: 50%;
      position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;
      transform: translate(-50%,-50%); transition: width 0.2s, height 0.2s;
      mix-blend-mode: multiply;
    }
    .cursor-ring {
      width: 32px; height: 32px; border: 1.5px solid var(--blue); border-radius: 50%;
      position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9998;
      transform: translate(-50%,-50%); opacity: 0.4;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.3rem 3rem;
      transition: background 0.4s, backdrop-filter 0.4s;
    }
    nav.scrolled { background: rgba(13,31,138,0.93); backdrop-filter: blur(16px); }
    .nav-logo {
      font-family: 'Playfair Display', serif; font-size: 1.6rem;
      font-weight: 900; color: white; letter-spacing: -0.5px;
    }
    .nav-logo span { font-style: italic; opacity: 0.6; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      color: rgba(255,255,255,0.8); text-decoration: none;
      font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em;
      text-transform: uppercase; transition: color 0.2s;
    }
    .nav-links a:hover { color: white; }

    section { min-height: 100vh; scroll-snap-align: start; position: relative; overflow: hidden; }

    /* HERO */
    #hero {
      background: var(--blue);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 7rem 2rem 4rem;
    }
    .hero-rings { position: absolute; inset: 0; pointer-events: none; }
    .hero-rings span {
      position: absolute; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.07);
      animation: rpulse 9s ease-in-out infinite;
    }
    .hero-rings span:nth-child(1){width:700px;height:700px;top:-200px;right:-180px;}
    .hero-rings span:nth-child(2){width:450px;height:450px;bottom:-120px;left:-120px;animation-delay:3s;}
    .hero-rings span:nth-child(3){width:280px;height:280px;top:30%;left:8%;animation-delay:6s;}
    @keyframes rpulse {
      0%,100%{transform:scale(1);opacity:0.35;} 50%{transform:scale(1.08);opacity:0.1;}
    }
    .hero-eyebrow {
      font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: rgba(255,255,255,0.5); margin-bottom: 1.5rem;
      position: relative; z-index: 1;
      opacity:0; animation: fadeUp 0.8s 0.3s forwards;
    }
    .hero-potato-wrap {
      position: relative; z-index: 1;
      opacity:0;
      animation: fadeUp 1s 0.5s forwards, potatoBounce 4s 1.5s ease-in-out infinite;
    }
    .hero-potato-wrap svg { width: 210px; height: 210px; filter: drop-shadow(0 24px 48px rgba(0,0,0,0.35)); }
    @keyframes potatoBounce {
      0%,100%{transform:translateY(0);} 50%{transform:translateY(-10px);}
    }
    .hero-brand {
      position: relative; z-index: 1;
      opacity:0; animation: fadeUp 0.9s 0.75s forwards;
    }
    .hero-brand-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 10vw, 7rem);
      font-weight: 900; color: white; letter-spacing: -2px; line-height: 1;
    }
    .hero-brand-name em { font-style: italic; color: rgba(255,255,255,0.4); }
    .hero-brand-sub {
      font-size: 0.78rem; letter-spacing: 0.22em;
      text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 0.5rem;
    }
    .hero-slogans {
      margin-top: 1.8rem; position: relative; z-index: 1;
      opacity:0; animation: fadeUp 0.9s 1s forwards;
      display: flex; gap: 1.5rem; align-items: center;
      flex-wrap: wrap; justify-content: center;
    }
    .hero-slogan { font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.5); }
    .hero-dot { color: rgba(255,255,255,0.2); }
    .hero-cta {
      margin-top: 2.5rem; position: relative; z-index: 1;
      display: inline-block; padding: 0.85rem 2.4rem;
      background: white; color: var(--blue);
      font-weight: 600; font-size: 0.88rem; letter-spacing: 0.05em;
      border-radius: 100px; text-decoration: none;
      opacity:0; animation: fadeUp 0.9s 1.2s forwards;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .hero-cta:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(255,255,255,0.2); }
    @keyframes fadeUp {
      from{ opacity:0; transform:translateY(24px); } to{ opacity:1; transform:translateY(0); }
    }

    /* ABOUT */
    #about { display: grid; grid-template-columns: 1fr 1fr; }
    .about-img-side { position: relative; min-height: 100vh; overflow: hidden; }
    .about-img-side img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
    .about-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(13,31,138,0.2), transparent);
    }
    .about-img-badge {
      position: absolute; bottom: 2.5rem; left: 2.5rem;
      background: rgba(255,255,255,0.12); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 12px;
      padding: 1rem 1.4rem; color: white;
    }
    .about-img-badge p:first-child {
      font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(255,255,255,0.55); margin-bottom: 0.2rem;
    }
    .about-img-badge p:last-child {
      font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700;
    }
    .about-text-side {
      background: var(--white); display: flex; flex-direction: column;
      justify-content: center; padding: 5rem 5rem 5rem 5.5rem;
    }
    .eyebrow {
      font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--blue); font-weight: 600; margin-bottom: 1rem;
    }
    .section-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 700; line-height: 1.1; color: #0c1840; margin-bottom: 1.6rem;
    }
    .section-heading em { font-style: italic; color: var(--blue); }
    .section-body { font-size: 1rem; line-height: 1.82; color: #4a4a5a; max-width: 440px; }
    .section-body + .section-body { margin-top: 1rem; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 2.2rem; }
    .tag {
      padding: 0.38rem 1rem; border: 1.5px solid rgba(26,53,204,0.25);
      border-radius: 100px; font-size: 0.78rem; color: var(--blue); font-weight: 500;
    }

    /* BUILD YOUR OWN */
    #build {
      background: var(--blue);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 7rem 5vw; text-align: center; position: relative;
    }
    #build::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 70% 30%, rgba(34,70,224,0.5), transparent 55%),
                  radial-gradient(ellipse at 20% 80%, rgba(13,31,138,0.6), transparent 50%);
    }
    .build-inner { position: relative; z-index: 1; max-width: 860px; width: 100%; }
    .build-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 7vw, 5.5rem);
      font-weight: 900; color: white; line-height: 0.95; margin-bottom: 0.8rem;
    }
    .build-title em { font-style: italic; color: rgba(255,255,255,0.4); }
    .build-tagline {
      font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(255,255,255,0.4); margin-bottom: 3.5rem;
    }
    .toppings-grid {
      display: flex; flex-wrap: wrap; gap: 0.9rem;
      justify-content: center; margin-bottom: 2.5rem;
    }
    .topping-chip {
      padding: 0.7rem 1.5rem;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 100px; color: white;
      font-size: 0.9rem; font-weight: 400;
      transition: background 0.2s, transform 0.2s; cursor: default;
    }
    .topping-chip:hover { background: rgba(255,255,255,0.2); transform: translateY(-2px); }
    .build-note { font-size: 0.85rem; color: rgba(255,255,255,0.35); letter-spacing: 0.05em; }

    /* STORY */
    #story {
      background: var(--cream); display: flex; flex-direction: column;
      align-items: center; justify-content: center; padding: 7rem 5vw;
    }
    .story-inner { max-width: 860px; width: 100%; }
    .story-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 900; line-height: 1.05; color: #0c1840; margin-bottom: 2rem;
    }
    .story-heading em { font-style: italic; color: var(--blue); }
    .story-placeholder {
      background: white; border-radius: 20px;
      border: 2px dashed rgba(26,53,204,0.15);
      padding: 4.5rem 3rem; text-align: center;
    }
    .story-placeholder strong {
      display: block; font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-style: italic; font-weight: 700;
      color: rgba(26,53,204,0.22); margin-bottom: 0.8rem;
    }
    .story-placeholder p { font-size: 0.9rem; color: #bbc; font-style: italic; line-height: 1.7; }

    /* INVITE */
    #invite {
      background: var(--white); display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 7rem 5vw; text-align: center;
    }
    .invite-inner { max-width: 680px; width: 100%; }
    .invite-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 7vw, 5rem);
      font-weight: 900; line-height: 1; color: #0c1840; margin-bottom: 1.4rem;
    }
    .invite-heading em { font-style: italic; color: var(--blue); }
    .invite-sub { font-size: 1rem; color: #5a5a70; line-height: 1.78; margin-bottom: 3rem; }
    .contact-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-bottom: 3rem; }
    .contact-card {
      background: var(--cream); border-radius: 16px; padding: 1.5rem 2rem;
      min-width: 185px; text-align: left; border: 1.5px solid transparent;
      transition: border-color 0.25s, transform 0.25s;
    }
    .contact-card:hover { border-color: rgba(26,53,204,0.25); transform: translateY(-3px); }
    .contact-label {
      font-size: 0.63rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--blue); font-weight: 600; margin-bottom: 0.45rem;
    }
    .contact-value { font-size: 0.95rem; font-weight: 500; color: #1a1a2e; }
    .contact-value.empty { color: #bbc; font-weight: 400; font-style: italic; font-size: 0.85rem; }
    .ig-btn {
      display: inline-flex; align-items: center; gap: 0.6rem;
      padding: 1rem 2.8rem; background: var(--blue); color: white;
      font-size: 0.92rem; font-weight: 600; letter-spacing: 0.04em;
      border-radius: 100px; text-decoration: none;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .ig-btn:hover { background: var(--blue-dark); transform: translateY(-3px); box-shadow: 0 14px 36px rgba(26,53,204,0.28); }

    footer {
      background: #080f3a; color: rgba(255,255,255,0.35); text-align: center;
      padding: 2.2rem; font-size: 0.8rem; letter-spacing: 0.04em;
      scroll-snap-align: start;
    }
    footer strong { color: rgba(255,255,255,0.65); }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    .d1{ transition-delay:0.12s; } .d2{ transition-delay:0.24s; }
    .d3{ transition-delay:0.36s; } .d4{ transition-delay:0.48s; }

    #fpotato {
      position: fixed; right: 3.5vw; top: 50%; transform: translateY(-50%);
      z-index: 40; pointer-events: none; width: 95px; transition: opacity 0.5s;
    }
    #fpotato.hide { opacity: 0; }

    @media(max-width:768px){
      nav { padding: 1rem 1.4rem; }
      .nav-links { display: none; }
      #about { grid-template-columns: 1fr; }
      .about-img-side { min-height: 60vw; }
      .about-text-side { padding: 2.8rem 1.8rem; }
      #fpotato { display: none; }
    }
  </style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cring"></div>

