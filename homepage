<nav id="nav">
  <div class="nav-logo">BLUE<span>RO</span></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#build">Menu</a></li>
    <li><a href="#story">Our Story</a></li>
    <li><a href="#invite">Invite Us</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-rings"><span></span><span></span><span></span></div>
  <p class="hero-eyebrow">Mumbai · India's First Kumpir Co.</p>
  <div class="hero-potato-wrap">
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
