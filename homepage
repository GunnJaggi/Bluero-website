<script>
  const cur = document.getElementById('cursor');
  const crng = document.getElementById('cring');
  let mx=0, my=0, rx=0, ry=0;
  document.addEventListener('mousemove', e => {
    mx=e.clientX; my=e.clientY;
    cur.style.left=mx+'px'; cur.style.top=my+'px';
  });
  setInterval(()=>{ rx+=(mx-rx)*0.18; ry+=(my-ry)*0.18; crng.style.left=rx+'px'; crng.style.top=ry+'px'; },16);
  document.querySelectorAll('a').forEach(a=>{
    a.addEventListener('mouseenter',()=>{cur.style.width='22px';cur.style.height='22px';});
    a.addEventListener('mouseleave',()=>{cur.style.width='12px';cur.style.height='12px';});
  });

  const nav=document.getElementById('nav');
  window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>70));

  const obs=new IntersectionObserver(
    es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:0.12}
  );
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

  const fp=document.getElementById('fpotato');
  const pc=document.getElementById('pc');
  const stm=document.getElementById('stm');
  const tops=document.getElementById('tops');
  const lbl=document.getElementById('lbl');
  window.addEventListener('scroll',()=>{
    const p=Math.min(scrollY/(document.body.scrollHeight-innerHeight),1);
    fp.classList.toggle('hide',scrollY<220);
    pc.style.strokeDasharray=`${Math.min(p*3,1)*200} 200`;
    stm.style.opacity=Math.min(Math.max((p-0.1)*5,0),1);
    tops.style.opacity=Math.min(Math.max((p-0.35)*4,0),1);
    lbl.style.opacity=Math.min(Math.max((p-0.65)*5,0),1);
    fp.style.transform=`translateY(calc(-50% + ${Math.sin(scrollY*0.012)*7}px))`;
  });
</script>
