  <div class="hero-slogans">
    <span class="hero-slogan">Baked. Stuffed. Yours.</span>
  </div>
  <a href="#about" class="hero-cta">Discover ↓</a>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="about-img-side">
    <img src="data:image/jpeg;base64," alt="Bluero Kumpir bowl"/>
    <div class="about-img-overlay"></div>
    <div class="about-img-badge">
      <p>Straight from</p>
      <p>Ortaköy, Istanbul</p>
    </div>
  </div>
  <div class="about-text-side">
    <p class="eyebrow reveal">What is Kumpir?</p>
    <h2 class="section-heading reveal d1">Istanbul's streets,<br/><em>Bombay's soul.</em></h2>
    <p class="section-body reveal d2">Kumpir is Turkey's legendary loaded baked potato — fluffy inside, crispy outside, mashed with butter and cheese, then piled with toppings you pick yourself.</p>
    <p class="section-body reveal d3">Bluero brings this to Mumbai without compromise. Same recipe. Same soul. A new home.</p>
    <div class="tags reveal d4">
      <span class="tag">🥔 Authentic Recipe</span>
      <span class="tag">📍 Bombay-Made</span>
      <span class="tag">🌍 Build Your Own</span>
      <span class="tag">🌶 Indian Twists</span>
    </div>
  </div>
</section>

<!-- BUILD YOUR OWN -->
<section id="build">
  <div class="build-inner">
    <p class="eyebrow reveal" style="color:rgba(255,255,255,0.45);">The Menu</p>
    <h2 class="build-title reveal d1">Build Your Own<br/><em>Kumpir.</em></h2>
    <p class="build-tagline reveal d2">Baked. Stuffed. Yours.</p>
    <div class="toppings-grid reveal d3">
      <span class="topping-chip">🧀 Cheese</span>
      <span class="topping-chip">🫒 Olives</span>
      <span class="topping-chip">🌽 Sweetcorn</span>
      <span class="topping-chip">🍅 Tomatoes</span>
      <span class="topping-chip">🧅 Onions</span>
      <span class="topping-chip">🌶 Jalapeños</span>
      <span class="topping-chip">🫘 Beans</span>
      <span class="topping-chip">🥒 Pickles</span>
      <span class="topping-chip">🥄 Sauces</span>
      <span class="topping-chip">✦ And more...</span>
    </div>
    <p class="build-note reveal d4">Start with our butter-mashed base. Pick your toppings. Make it yours.</p>
  </div>
</section>

<!-- OUR STORY -->
<section id="story">
  <div class="story-inner">
    <p class="eyebrow reveal">Our Story</p>
    <h2 class="story-heading reveal d1">More than<br/><em>a potato.</em></h2>
    <div class="story-placeholder reveal d2">
      <strong>‹ Founder Story ›</strong>
      <p>Coming soon — told in the founder's own words.</p>
    </div>
  </div>
</section>

<!-- INVITE US -->
<section id="invite">
  <div class="invite-inner">
    <p class="eyebrow reveal">Invite Us</p>
    <h2 class="invite-heading reveal d1">Let's bring<br/><em>Bluero</em> to you.</h2>
    <p class="invite-sub reveal d2">Pop-ups, corporate events, festivals, private parties — get in touch and let's make something great together.</p>
    <div class="contact-row reveal d3">
      <div class="contact-card">
        <p class="contact-label">Phone</p>
        <p class="contact-value empty">Coming soon</p>
      </div>
      <div class="contact-card">
        <p class="contact-label">Email</p>
        <p class="contact-value empty">Coming soon</p>
      </div>
